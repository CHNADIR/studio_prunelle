{% extends 'base.html.twig' %}

{% block title %}Détail Planche: {{ planche.nom }}{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1>Détail de la Planche</h1>

        <table class="table">
            <tbody>
                <tr>
                    <th>Id</th>
                    <td>{{ planche.id }}</td>
                </tr>
                <tr>
                    <th>Nom</th>
                    <td>{{ planche.nom }}</td>
                </tr>
                <tr>
                    <th>Catégorie</th>
                    <td>{{ planche.categorie }}</td>
                </tr>
                <tr>
                    <th>Image</th>
                    <td>
                        {% if planche.imageFilename %}
                            <img src="{{ ('planches/' ~ planche.imageFilename) | imagine_filter('planche_medium') }}" alt="{{ planche.nom }}" class="img-fluid" style="max-width: 400px;">
                            <p class="mt-2">
                                <a href="{{ path('app_secure_planche_image_original', {'filename': planche.imageFilename }) }}" class="btn btn-sm btn-outline-secondary" target="_blank">
                                    <i class="bi bi-download"></i> Voir l'original (sécurisé)
                                </a>
                            </p>
                        {% else %}
                            Aucune image.
                        {% endif %}
                    </td>
                </tr>
            </tbody>
        </table>

        <div class="mt-3">
            <a href="{{ path('app_planche_index') }}" class="btn btn-secondary">Retour à la liste</a>
            {% if is_granted('ROLE_ADMIN') %} {# Ou un autre rôle/permission approprié pour l'édition #}
                <a href="{{ path('app_planche_edit', {'id': planche.id}) }}" class="btn btn-warning">Modifier</a>
            {% endif %}
        </div>
    </div>
{% endblock %}

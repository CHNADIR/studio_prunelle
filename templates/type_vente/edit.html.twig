{% extends 'base.html.twig' %}

{% block title %}Modifier {{ entity_name_singular|title }}: {{ type_vente.nom }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Modifier {{ entity_name_singular|title }}: <span class="text-primary">{{ type_vente.nom }}</span></h1>
        <a href="{{ path(index_route_name) }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour à la liste
        </a>
    </div>

    {{ include('type_vente/_form.html.twig', {'button_label': 'Mettre à jour', 'form': form}) }}

    {% if is_granted('ROLE_ADMIN') and not is_new %}
    <div class="mt-3">
        {# Simplification: suppression du paramètre delete_route_name #}
        {{ include('type_vente/_delete_form.html.twig', { 'type_vente': type_vente }) }}
    </div>
    {% endif %}
</div>
{% endblock %}

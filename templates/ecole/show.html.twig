{% extends 'base.html.twig' %}

{% block title %}Fiche École: {{ ecole.nom }}{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1>Fiche École: {{ ecole.nom }}</h1>

        <div class="card mb-4">
            <div class="card-header">
                Informations Générales
            </div>
            <div class="card-body">
                <table class="table table-borderless table-sm">
                    <tbody>
                        <tr>
                            <th style="width: 20%;">Code</th>
                            <td>{{ ecole.code }}</td>
                        </tr>
                        <tr>
                            <th>Genre</th>
                            <td>{{ ecole.genre }}</td>
                        </tr>
                        <tr>
                            <th>Nom</th>
                            <td>{{ ecole.nom }}</td>
                        </tr>
                        <tr>
                            <th>Adresse</th>
                            <td>{{ ecole.rue }}, {{ ecole.codePostal }} {{ ecole.ville }}</td>
                        </tr>
                        <tr>
                            <th>Téléphone</th>
                            <td>{{ ecole.telephone|default('N/A') }}</td>
                        </tr>
                        <tr>
                            <th>Email</th>
                            <td>{{ ecole.email|default('N/A') }}</td>
                        </tr>
                        <tr>
                            <th>Statut</th>
                            <td>
                                <span class="badge {{ ecole.active ? 'bg-success' : 'bg-danger' }}">
                                    {{ ecole.active ? 'Active' : 'Inactive' }}
                                </span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                Dernières Prises de Vue
            </div>
            <div class="card-body">
                {% if dernieres_prises_de_vue is not empty %}
                    <div class="table-responsive">
                        <table class="table table-striped table-hover table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Type de Prise</th>
                                    <th>Thème</th>
                                    <th>Photographe</th>
                                    <th>Nb Élèves</th>
                                    <th>Planches Individuelles</th>
                                    <th>Planches Fratrie</th>
                                    <th>Prix École</th>
                                    <th>Prix Parent</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for pdv in dernieres_prises_de_vue %}
                                    <tr>
                                        <td>{{ pdv.date ? pdv.date|date('d/m/Y') : '' }}</td>
                                        <td>{{ pdv.typePrise ? pdv.typePrise.nom : 'N/A' }}</td>
                                        <td>{{ pdv.theme ? pdv.theme.nom : 'N/A' }}</td>
                                        <td>{{ pdv.photographe|default('N/A') }}</td>
                                        <td>{{ pdv.nombreEleves|default('N/A') }}</td>
                                        <td>
                                            {% if pdv.planchesIndividuel is not empty %}
                                                {% for planche in pdv.planchesIndividuel %} 
                                                    <span class="badge bg-secondary">{{ planche.nom }}</span>
                                                {% endfor %}
                                            {% else %}
                                                N/A
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if pdv.planchesFratrie is not empty %}
                                                {% for planche in pdv.planchesFratrie %}
                                                    <span class="badge bg-info text-dark">{{ planche.nom }}</span>
                                                {% endfor %}
                                            {% else %}
                                                N/A
                                            {% endif %}
                                        </td>
                                        <td>{{ pdv.prixEcole|number_format(2, ',', ' ') }} €</td>
                                        <td>{{ pdv.prixParent|number_format(2, ',', ' ') }} €</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <p class="text-muted">Aucune prise de vue récente enregistrée pour cette école.</p>
                {% endif %}
            </div>
        </div>

        <div class="mt-3">
            <a href="{{ path('app_ecole_index') }}" class="btn btn-secondary">
                <i class="bi bi-arrow-left-circle"></i> Retour à la liste
            </a>
            {% if is_granted('ROLE_ADMIN') %} {# Ou une permission plus spécifique comme EcoleVoter::EDIT #}
                <a href="{{ path('app_ecole_edit', {'id': ecole.id}) }}" class="btn btn-warning">
                    <i class="bi bi-pencil"></i> Modifier l'école
                </a>
            {% endif %}
        </div>
    </div>
{% endblock %}

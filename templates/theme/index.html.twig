{% extends 'base.html.twig' %}

{% block title %}Liste des Thèmes{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Liste des Thèmes</h1>
        <a href="{{ path('app_theme_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Ajouter un thème
        </a>
    </div>

    <form method="get" action="{{ path('app_theme_index') }}" class="mb-3">
        <div class="input-group">
            <input type="text" name="search" class="form-control" placeholder="Rechercher par nom..." value="{{ current_search|default('') }}">
            <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i> Rechercher</button>
            {% if current_search %}
                <a href="{{ path('app_theme_index') }}" class="btn btn-outline-danger" title="Effacer la recherche"><i class="bi bi-x-lg"></i></a>
            {% endif %}
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>{{ knp_pagination_sortable(themes, 'ID', 't.id') }}</th>
                    <th>{{ knp_pagination_sortable(themes, 'Nom', 't.nom') }}</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for theme in themes %}
                <tr>
                    <td>{{ theme.id }}</td>
                    <td>{{ theme.nom }}</td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            <a href="{{ path('app_theme_show', {'id': theme.id}) }}" class="btn btn-info" title="Voir"><i class="bi bi-eye"></i></a>
                            <a href="{{ path('app_theme_edit', {'id': theme.id}) }}" class="btn btn-warning" title="Modifier"><i class="bi bi-pencil"></i></a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="3" class="text-center fst-italic">Aucun thème trouvé.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="navigation d-flex justify-content-center mt-3">
        {{ knp_pagination_render(themes) }}
    </div>
    <div class="text-center text-muted small">
        Affichage de {{ themes.getTotalItemCount > 0 ? themes.getPaginationData().firstItemNumber : 0 }}
        à {{ themes.getPaginationData().lastItemNumber }}
        sur {{ themes.getTotalItemCount }} thème(s).
    </div>
</div>
{% endblock %}

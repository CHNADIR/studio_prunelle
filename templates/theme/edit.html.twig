{% extends 'base.html.twig' %}

{% block title %}Modifier Thème: {{ theme.nom }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Modifier Thème: <span class="text-primary">{{ theme.nom }}</span></h1>
        <a href="{{ path('app_theme_index') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour à la liste
        </a>
    </div>

    {{ include('theme/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

    <div class="mt-3">
        {{ include('theme/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
